# We do not have a toolchain for avr32 outside of Microchip login wall.
# The work was never upstreamed to GCC.
/avr

# PINGUINOL toolchain doesn't provide macOS binaries
# with the same name
/mips,CONFIG_MIPS32_TOOLCHAIN_PINGUINOL

