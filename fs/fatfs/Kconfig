#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

menuconfig FS_FATFS
	bool "FATFS File System"
	default n
	depends on !DISABLE_MOUNTPOINT
	---help---
		Build the FATFS file system. http://elm-chan.org/fsw/ff/00index_e.html

config FS_FATFS_SECTOR_RATIO
	int "The ratio between fatfs filesystem sector and block device sector"
	depends on FS_FATFS
	default 1

config FS_FATFS_ERROR_LOG
	bool "FATFS file system output detail error log"
	depends on DEBUG_FS_ERROR
	---help---
		Enable FATFS file system detail error log.