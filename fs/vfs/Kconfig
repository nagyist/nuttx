#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

config EVENT_FD
	bool "EventFD"
	default n
	---help---
		Create a file descriptor for event notification

if EVENT_FD

config EVENT_FD_POLL
	bool "EventFD poll support"
	default y
	---help---
		Poll support for file descriptor based events

config EVENT_FD_NPOLLWAITERS
	int "Number of eventFD poll waiters"
	default 2
	depends on EVENT_FD_POLL
	---help---
		Maximum number of threads that can be waiting on poll()

endif # EVENT_FD

config TIMER_FD
	bool "TimerFD"
	default n
	---help---
		Create a file descriptor for timer notification

if TIMER_FD

config TIMER_FD_POLL
	bool "TimerFD poll support"
	default y
	---help---
		Poll support for file descriptor based timers

config TIMER_FD_NPOLLWAITERS
	int "Number of timerFD poll waiters"
	default 2
	depends on TIMER_FD_POLL
	---help---
		Maximum number of threads that can be waiting on poll()

endif # TIMER_FD

config SIGNAL_FD
	bool "SignalFD"
	depends on !DISABLE_SIGNALS
	default n
	---help---
		Create a file descriptor for accepting signals

if SIGNAL_FD

config SIGNAL_FD_NPOLLWAITERS
	int "Number of signalFD poll waiters"
	default 2
	---help---
		Maximum number of threads that can be waiting on poll()

endif # SIGNAL_FD

config FS_NOTIFY
	bool "FS Notify System"
	default n
	---help---
		The Fsnotify System

if FS_NOTIFY
config FS_NOTIFY_BUCKET_SIZE
	int "Dir hash bucket size"
	default 64

config FS_NOTIFY_MAX_EVENTS
	int "Max events in one notify device"
	default 1024

config FS_NOTIFY_FD_POLLWAITERS
	int "Max pollwaiters in one notify device"
	default 2

endif # FS_NOTIFY

config FS_BACKTRACE
	bool "VFS backtrace"
	default n
	depends on LIBC_BACKTRACE_DEPTH > 0
	---help---
		Add backtrace to vfs file open.

config FS_BACKTRACE_SKIP
	int "Backtrace to skip"
	default 4
	depends on FS_BACKTRACE
	---help---
		Skip depth of backtrace.

config FS_PATHCACHE
	bool "Pathcache of struct file"
	default n
	depends on !DISABLE_MOUNTPOINT
	---help---
		Enable caching of struct file to accelerate file open operations.
		When a file is opened, its metadata (stored in struct file) is
		cached and reused on subsequent opens, avoiding the overhead of
		repeated filesystem-specific open operations.

if FS_PATHCACHE

config FS_PATHCACHE_MAX_ENTRIES
	int "Maximum number of cached files"
	default 64
	---help---
		The maximum number of file entries that can be cached. When this
		limit is reached, the least recently used (LRU) entry will be
		evicted to make room for new entries.

config FS_PATHCACHE_HASH_SIZE
	int "Pathcache hash table size"
	default 32
	---help---
		The size of the hash table used for the pathcache. The value
		should be a power of 2 for optimal hash distribution.

endif # FS_PATHCACHE
